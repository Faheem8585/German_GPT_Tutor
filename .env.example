# ─── Application ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
APP_NAME=GermanGPT Tutor
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=change_this_to_a_secure_random_string_in_production
JWT_SECRET=change_this_jwt_secret_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080  # 7 days

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=germangpt
POSTGRES_PASSWORD=germangpt_secret
POSTGRES_DB=germangpt
DATABASE_URL=postgresql+asyncpg://germangpt:germangpt_secret@localhost:5432/germangpt

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379/0

# ─── Vector DB ────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=germangpt_knowledge

# ─── LLM Providers ───────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# Default model provider: openai | anthropic | gemini | ollama
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_CHAT_MODEL=claude-sonnet-4-6
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small

# ─── Voice AI ─────────────────────────────────────────────────────────────────
OPENAI_WHISPER_MODEL=whisper-1
TTS_PROVIDER=openai  # openai | elevenlabs | azure
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB  # German voice

# ─── Ollama (local models) ────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Observability ───────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=germangpt-tutor
LANGCHAIN_TRACING_V2=false

# ─── Security ─────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
RATE_LIMIT_PER_MINUTE=60
MAX_AUDIO_SIZE_MB=25

# ─── Feature Flags ────────────────────────────────────────────────────────────
ENABLE_VOICE=true
ENABLE_GAMES=true
ENABLE_MULTIPLAYER=false
ENABLE_ANALYTICS=true
ENABLE_RAG=true
